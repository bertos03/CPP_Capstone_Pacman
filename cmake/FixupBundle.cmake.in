include(BundleUtilities)

set(BU_CHMOD_BUNDLE_ITEMS ON)
set(PACMAN_BUNDLE_PATH "$ENV{DESTDIR}${CMAKE_INSTALL_PREFIX}/pacman.app")
set(PACMAN_BUNDLE_SEARCH_DIRS "@PACMAN_BUNDLE_SEARCH_DIRS@")

fixup_bundle("${PACMAN_BUNDLE_PATH}" "" "${PACMAN_BUNDLE_SEARCH_DIRS}")
verify_app("${PACMAN_BUNDLE_PATH}")
